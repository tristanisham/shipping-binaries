# OpenWeather API key — free "Current Weather Data" plan:
# https://openweathermap.org/api  (Current Weather Data → /data/2.5/weather)
#
# Local dev:  copy this file to `.env` and fill in the key.
# Vercel:     add OPENWEATHER_API_KEY as a Project Environment Variable.
#
# Without a key the header widget still shows the clock and city picker;
# weather (icon/temperature) simply reports as unavailable.
OPENWEATHER_API_KEY=
