{
  "name": "hono",
  "type": "module",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.12.31",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@hono/node-server": "^2.0.10",
    "@hono/vite-dev-server": "^0.26.1",
    "@tailwindcss/cli": "^4.3.3",
    "@types/node": "^26.1.1",
    "concurrently": "^9.2.4",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vite": "^8.1.5",
    "wrangler": "^4.112.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "@parcel/watcher@2.5.1": true
  },
  "scripts": {
    "account:create": "node --env-file-if-exists=.env --import=tsx src/scripts/create-owner.ts",
    "build": "npm run build:css",
    "build:css": "tailwindcss -i ./src/styles.css -o ./public/styles.css --minify",
    "dev": "npm run build:css && concurrently --kill-others-on-fail \"npm:dev:worker\" \"npm:dev:css\"",
    "dev:css": "tailwindcss -i ./src/styles.css -o ./public/styles.css --watch",
    "dev:server": "vite",
    "dev:worker": "wrangler dev --persist-to=${DATABASE_URL:-.wrangler/state}",
    "db:migrate:local": "wrangler d1 migrations apply shipping-binaries --local --persist-to=${DATABASE_URL:-.wrangler/state}",
    "db:migrate:remote": "wrangler d1 migrations apply shipping-binaries --remote",
    "deploy": "wrangler deploy",
    "start": "node --import=tsx src/dev.ts",
    "types:worker": "wrangler types src/worker-configuration.d.ts",
    "typecheck": "tsc --noEmit",
    "test": "NODE_OPTIONS=\"--import tsx\" node --test \"tests/**/*.test.ts\""
  }
}
